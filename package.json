{
  "dependencies": {
    "dotenv": "^16.4.5"
  },
  "prisma": {
    "schema": "backend/prisma/schema.prisma"
  },
  "devDependencies": {
    "jest-environment-jsdom": "^29.7.0",
    "jsdom": "^21.1.1"
  },
  "scripts": {
    "test:all": "npm run test:backend && npm run test:frontend",
    "test:backend": "cd backend && npm run test:coverage",
    "test:frontend": "cd frontend && npm run test:coverage",
    "test:reports": "node scripts/generate-test-reports.js",
    "test:reports:view": "npm run test:reports && python3 -m http.server 8080",
    "test:coverage": "npm run test:all && npm run test:reports",
    "test:coverage:view": "npm run test:coverage && python3 -m http.server 8080"
  }
}
